# ====== GCP / BigQuery ======
GCP_PROJECT_ID=my-gcp-project
GCP_REGION=US
BQ_BRONZE_DATASET=ecom_bronze
BQ_SILVER_DATASET=ecom_silver
BQ_GOLD_DATASET=ecom_gold
BQ_AUDIT_DATASET=ecom_audit
GOOGLE_APPLICATION_CREDENTIALS=/opt/secrets/gcp-key.json
GCS_STAGING_BUCKET=my-ecom-staging-bucket

# ====== Local data paths ======
DATA_ROOT=./data
RAW_PATH=./data/raw
CDC_PATH=./data/cdc
BRONZE_PATH=./data/bronze
SILVER_PATH=./data/silver
GOLD_PATH=./data/gold

# ====== Spark ======
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g

# ====== Airflow ======
AIRFLOW_UID=50000
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW_ALERT_EMAIL=data-alerts@example.com
AIRFLOW__SMTP__SMTP_HOST=smtp.example.com
AIRFLOW__SMTP__SMTP_USER=alerts@example.com
AIRFLOW__SMTP__SMTP_PASSWORD=changeme
AIRFLOW__SMTP__SMTP_PORT=587

# ====== Kaggle (for dataset download) ======
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key

# ====== dbt ======
DBT_PROFILES_DIR=./dbt
DBT_TARGET=dev
